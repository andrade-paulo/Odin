# Ignore build artifacts produced by ESP-IDF/CMake
/build/
/**/build/

# SDK config files (keep out of repo if you customize per-device)
sdkconfig
sdkconfig.old
sdkconfig.cmake
sdkconfig.h

# CMake / Ninja outputs
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json

