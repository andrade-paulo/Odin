*.log
*.tmp
*.swp
*~

# ESP tool outputs and images
*.bin
*.elf
*.map
*.hex

# Partition/flash helper files
flash_args
flash_args.*
flasher_args.json
flasher_args.json.in

# IDE/editor files
.vscode/
.idea/
*.iml

# Python virtualenvs and caches
.python_env/
venv/
env/
*.venv/
__pycache__/
*.pyc

# macOS / Windows
.DS_Store
Thumbs.db

# PlatformIO
.pio/

# Misc
.cache/
.pytest_cache/